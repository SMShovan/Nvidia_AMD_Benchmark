# Resolve BENCH_BACKEND from the BACKEND cache option.
if(NOT DEFINED BACKEND OR BACKEND STREQUAL "AUTO")
  include(CheckLanguage)
  check_language(CUDA)
  if(CMAKE_CUDA_COMPILER)
    set(BENCH_BACKEND "CUDA")
  else()
    check_language(HIP)
    if(CMAKE_HIP_COMPILER)
      set(BENCH_BACKEND "HIP")
    else()
      set(BENCH_BACKEND "CPU")
    endif()
  endif()
else()
  set(BENCH_BACKEND "${BACKEND}")
endif()
